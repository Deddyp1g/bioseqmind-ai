BIOSEQMIND_DB_PATH=data/bioseqmind.sqlite3
BIOSEQMIND_CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# geNomad: install the command and point this to the downloaded genomad_db directory.
BIOSEQMIND_GENOMAD_COMMAND=genomad
BIOSEQMIND_GENOMAD_DB_PATH=
BIOSEQMIND_GENOMAD_MODE=fast_nn
BIOSEQMIND_GENOMAD_SINGLE_WINDOW=true
BIOSEQMIND_GENOMAD_THREADS=24
BIOSEQMIND_GENOMAD_SPLITS=0
BIOSEQMIND_GENOMAD_TIMEOUT_SECONDS=3600

# NCBI: live mode only. The app must fail instead of fabricating fallback hits.
BIOSEQMIND_NCBI_MODE=live
BIOSEQMIND_NCBI_EMAIL=bioseqmind@example.com
BIOSEQMIND_NCBI_TIMEOUT_SECONDS=300

# DeepSeek OpenAI-compatible API.
DEEPSEEK_API_KEY=
BIOSEQMIND_DEEPSEEK_BASE_URL=https://api.deepseek.com
BIOSEQMIND_DEEPSEEK_MODEL=deepseek-v4-flash
